l","id":"ggmQu06O_Me_srcSet_desktop_src","label":"ggmQu06O_Me_srcSet_desktop_src","default":"https://cdn.shopify.com/s/files/1/0673/2562/4490/files/section2.webp"},{"type":"html","id":"ggmQu06O_Me_srcSet_mobile_src","label":"ggmQu06O_Me_srcSet_mobile_src","default":"https://cdn.shopify.com/s/files/1/0673/2562/4490/files/section2.webp"}],
