    <script>
function getAllUrlParams() {
    var params = {};
    var queryString = window.location.search.substring(1);
    var vars = queryString.split('&');
    for (var i = 0; i < vars.length; i++) {
        var pair = vars[i].split('=');
        if (pair[0]) {
            params[pair[0]] = decodeURIComponent(pair[1] || '');
        }
    }
    return params;
}

function buildParamString(params) {
    var paramArray = [];
    for (var key in params) {
        if (params.hasOwnProperty(key) && params[key]) {
            paramArray.push(key + '=' + encodeURIComponent(params[key]));
        }
    }
    return paramArray.join('&');
}

function updateLinks() {
    var allParams = getAllUrlParams();
    var paramString = buildParamString(allParams);
    var yourBrandButtons = document.querySelectorAll('a[href*="solydia.com"]');
    
    if (yourBrandButtons.length > 0) {
        yourBrandButtons.forEach(function(button) {
            var currentHref = button.getAttribute('href');
            var separator = currentHref.includes('?') ? '&' : '?';
            button.setAttribute('href', currentHref + separator + paramString);
            button.removeAttribute('rel');
        });
        return true;
    }
    return false;
}

var attempts = 0;
var maxAttempts = 20;
var checkInterval = setInterval(function() {
    attempts++;
    if (updateLinks() || attempts >= maxAttempts) {
        clearInterval(checkInterval);
    }
}, 100);

window.addEventListener('load', updateLinks);
document.addEventListener('DOMContentLoaded', updateLinks);
</script>
